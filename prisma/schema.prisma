generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model exam_questions {
  exam_id         String        @db.VarChar(36)
  question_id     String        @db.VarChar(36)
  marks_weightage Int
  exams           exams         @relation(fields: [exam_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_eq_exam_id")
  question_bank   question_bank @relation(fields: [question_id], references: [id], onUpdate: NoAction, map: "fk_eq_question_id")

  @@id([exam_id, question_id])
  @@index([question_id], map: "fk_eq_question_id")
}

model exams {
  id                     String                  @id @db.VarChar(36)
  title                  String                  @db.VarChar(255)
  start_password_hash    String                  @db.VarChar(255)
  is_active              Boolean?                @default(false)
  is_live                Boolean?                @default(false)
  result_published       Boolean?                @default(false)
  total_marks            Int
  duration_minutes       Int
  target_graduation_year Int
  start_time             DateTime                @db.Timestamp(0)
  end_time               DateTime                @db.Timestamp(0)
  created_by             String?                 @db.VarChar(36)
  created_at             DateTime?               @default(now()) @db.Timestamp(0)
  exam_questions         exam_questions[]
  exam_target_sections   exam_target_sections[]
  users                  users?                  @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_exams_created_by")
  student_exam_sessions  student_exam_sessions[]

  @@index([created_by], map: "fk_exams_created_by")
  @@index([target_graduation_year, is_live, is_active], map: "idx_exams_live_targeting")
}

model question_bank {
  id             String                   @id @db.VarChar(36)
  title          String                   @db.VarChar(255)
  description    String                   @db.Text
  subject_tag    String                   @db.VarChar(100)
  difficulty     question_bank_difficulty
  created_by     String?                  @db.VarChar(36)
  created_at     DateTime?                @default(now()) @db.Timestamp(0)
  exam_questions exam_questions[]
  users          users?                   @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_qb_created_by")
  submissions    submissions[]
  test_cases     test_cases[]

  @@index([created_by], map: "fk_qb_created_by")
}

model student_exam_sessions {
  id           String                       @id @db.VarChar(36)
  exam_id      String                       @db.VarChar(36)
  student_id   String                       @db.VarChar(36)
  status       student_exam_sessions_status @default(allocated)
  started_at   DateTime?                    @db.Timestamp(0)
  submitted_at DateTime?                    @db.Timestamp(0)
  ip_address   String?                      @db.VarChar(45)
  exams        exams                        @relation(fields: [exam_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ses_exam_id")
  users        users                        @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ses_student_id")
  submissions  submissions[]

  @@unique([exam_id, student_id], map: "uq_exam_student")
  @@index([student_id], map: "fk_ses_student_id")
}

model submissions {
  id                    String                         @id @db.VarChar(36)
  session_id            String                         @db.VarChar(36)
  question_id           String                         @db.VarChar(36)
  submitted_code        String                         @db.Text
  language              String                         @db.VarChar(20)
  autograding_status    submissions_autograding_status @default(pending)
  autograding_score     Int                            @default(0)
  manual_score          Int?
  created_at            DateTime?                      @default(now()) @db.Timestamp(0)
  question_bank         question_bank                  @relation(fields: [question_id], references: [id], onUpdate: NoAction, map: "fk_sub_question_id")
  student_exam_sessions student_exam_sessions          @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sub_session_id")

  @@index([question_id], map: "fk_sub_question_id")
  @@index([session_id], map: "fk_sub_session_id")
  @@index([autograding_status], map: "idx_submissions_grading_queue")
}

model test_cases {
  id              String        @id @db.VarChar(36)
  question_id     String        @db.VarChar(36)
  input_data      String        @db.Text
  expected_output String        @db.Text
  is_hidden       Boolean?      @default(true)
  created_at      DateTime?     @default(now()) @db.Timestamp(0)
  question_bank   question_bank @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tc_question_id")

  @@index([question_id], map: "fk_tc_question_id")
}

model users {
  id                    String                  @id @db.VarChar(36)
  university_id         String                  @unique(map: "university_id") @db.VarChar(50)
  name                  String                  @db.VarChar(255)
  email                 String                  @unique(map: "email") @db.VarChar(255)
  password_hash         String                  @db.VarChar(255)
  role                  users_role
  graduation_year       Int?
  section               String?                 @db.VarChar(10)
  created_at            DateTime?               @default(now()) @db.Timestamp(0)
  exams                 exams[]
  question_bank         question_bank[]
  student_exam_sessions student_exam_sessions[]
}

model exam_target_sections {
  exam_id String @db.Char(36)
  section String @db.VarChar(10)
  exams   exams  @relation(fields: [exam_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ets_exam_id")

  @@id([exam_id, section])
  @@index([section], map: "idx_ets_section")
}

enum student_exam_sessions_status {
  allocated
  ongoing
  submitted
  absent
}

enum question_bank_difficulty {
  easy
  medium
  hard
}

enum users_role {
  admin
  faculty
  student
}

enum submissions_autograding_status {
  pending
  passed
  failed
  error
}
